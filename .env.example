# ========================================
# 서버 설정
# ========================================
PORT=5000

# ========================================
# 데이터베이스 설정
# ========================================
# DB_TYPE: sqlite (로컬 개발) 또는 mysql (AWS RDS)
DB_TYPE=sqlite

# MySQL 사용 시 필요 (DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=ecommerce

# ========================================
# 캐시 설정
# ========================================
# CACHE_TYPE: memory (로컬 개발) 또는 redis (AWS ElastiCache)
CACHE_TYPE=memory

# Redis 사용 시 필요 (CACHE_TYPE=redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# ========================================
# 파일 스토리지 설정
# ========================================
# STORAGE_TYPE: local (로컬 개발) 또는 s3 (AWS S3)
STORAGE_TYPE=local

# S3 사용 시 필요 (STORAGE_TYPE=s3)
S3_BUCKET=your-bucket-name
S3_REGION=ap-northeast-2

# ========================================
# AWS DynamoDB 설정
# ========================================
DYNAMODB_REGION=ap-northeast-2

# ========================================
# JWT 인증 설정
# ========================================
# 보안을 위해 강력한 랜덤 문자열을 사용하세요
# 예: openssl rand -base64 32
JWT_SECRET=your-secret-key-here
